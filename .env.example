# LLM Server Watchdog — Example Configuration
# Copy to .env and edit for your setup. Do NOT commit .env.

# Target llama.cpp server
LLM_STATUS_HOST=127.0.0.1
LLM_STATUS_PORT=8080

# Dashboard server port
LLM_STATUS_PORT_LISTEN=8124

# Polling intervals (seconds)
LLM_STATUS_POLL_FAST=1
LLM_STATUS_POLL=3

# Dashboard listen address (0.0.0.0 or 127.0.0.1)
LLM_STATUS_LISTEN_ADDR=0.0.0.0
